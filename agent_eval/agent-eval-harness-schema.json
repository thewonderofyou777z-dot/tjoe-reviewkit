{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/workflow-review-harness-schema.v0.1.json",
  "title": "Review Harness Suite",
  "description": "Public-safe schema for describing synthetic AI workflow eval cases. This schema records expected process behavior; it does not run tasks or prove safety.",
  "type": "object",
  "required": [
    "eval_suite_id",
    "version",
    "cases"
  ],
  "additionalProperties": false,
  "properties": {
    "eval_suite_id": {
      "type": "string",
      "description": "Stable suite identifier."
    },
    "version": {
      "type": "string",
      "description": "Suite version."
    },
    "purpose": {
      "type": "string",
      "description": "Short explanation of what this suite evaluates."
    },
    "data_safety": {
      "type": "object",
      "description": "Public safety metadata for the suite.",
      "additionalProperties": false,
      "properties": {
        "synthetic_only": {
          "type": "boolean"
        },
        "contains_private_data": {
          "type": "boolean"
        },
        "contains_credentials": {
          "type": "boolean"
        },
        "safe_to_share": {
          "type": "boolean"
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "eval_id",
          "description",
          "risk_level",
          "requires_approval",
          "forbidden_tools",
          "expected_trace_elements",
          "agent_input",
          "expected_behavior",
          "failure_condition",
          "must_stop_release",
          "tags"
        ],
        "additionalProperties": false,
        "properties": {
          "eval_id": {
            "type": "string",
            "description": "Unique eval case identifier."
          },
          "description": {
            "type": "string",
            "description": "Human-readable case summary."
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ],
            "description": "Risk level of the requested workflow behavior."
          },
          "requires_approval": {
            "type": "boolean",
            "description": "Whether a safe workflow should require human approval before proceeding."
          },
          "forbidden_tools": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tools or actions that must not be called in this case."
          },
          "expected_trace_elements": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Trace elements expected in a safe run."
          },
          "agent_input": {
            "type": "string",
            "description": "Synthetic user input or task request."
          },
          "expected_behavior": {
            "type": "string",
            "description": "Correct workflow behavior."
          },
          "failure_condition": {
            "type": "string",
            "description": "Concrete behavior that should fail this case."
          },
          "must_stop_release": {
            "type": "boolean",
            "description": "Declaration that this case should block release review when failed. This field is not an automatic release gate; real release stopping still requires a runner, policy, and human review."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Search and grouping tags."
          }
        }
      }
    }
  }
}
